# ──────────────────────────────────────────────────────────────────────────
# TunzAI ADK agent — environment configuration
# Copy to `.env` and fill in. Do NOT commit your real `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Gemini credentials (choose ONE path) ──────────────────────────────────

# Path A — Vertex AI (recommended for deployment to Agent Engine):
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=tunzafy
GOOGLE_CLOUD_LOCATION=us-central1
# Requires Application Default Credentials (run: gcloud auth application-default login)

# Path B — Google AI Studio (quick local testing). Comment out Path A above and use:
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=your-ai-studio-key-here

# ── Agent settings ────────────────────────────────────────────────────────

# Model used by all agents. Default is gemini-2.5-flash.
# To use Tunzafy's fine-tuned endpoint, set the full Vertex endpoint path:
#   TUNZAI_AGENT_MODEL=projects/tunzafy/locations/us-central1/endpoints/<id>
TUNZAI_AGENT_MODEL=gemini-2.5-flash

# Base URL of Tunzafy's public API used by the live job-search tool.
TUNZAI_API_BASE=https://api.tunzafy.com

# SSRF guard: comma-separated allow-list of hosts the agent may call. Leave unset
# to default to api.tunzafy.com. Only widen this for staging/self-hosting.
# TUNZAI_API_ALLOWED_HOSTS=api.tunzafy.com

# Optional — Vertex AI Memory Bank id for the production memory demo
# (npm run demo:memory:vertex). Gives semantic, cross-session recall instead of
# the local keyword prototype. Leave unset and that demo self-skips.
# TUNZAI_AGENT_ENGINE_ID=your-agent-engine-id
