# ─────────────────────────────────────────────────────────────────────
# Tunzafy API Server — environment variable template
#
# COPY this file to one of:
#   .env.local   → loaded automatically by `pnpm dev`
#   .env.test    → loaded by `pnpm dev:test-keys` (use sk_test_… keys here)
#
# Both .env.local and .env.test are gitignored. NEVER commit real secrets.
#
# PRODUCTION DOES NOT READ THIS FILE.
# Production Cloud Run env comes from the root env.yaml + Google Secret Manager.
# To rotate a prod secret: update Secret Manager + redeploy Cloud Run.
# ─────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Stripe ───────────────────────────────────────────────────────────
# For local dev use TEST keys (sk_test_… / whsec_… from Stripe Dashboard
# → Developers → API keys (test mode) and → Webhooks (test mode)).
# Real charges are NEVER made with test keys.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Auth / Sessions ──────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_64_hex_chars_minimum_32_bytes
JWT_SECRET=replace_with_64_hex_chars_minimum_32_bytes

# ── Database ─────────────────────────────────────────────────────────
# For local dev point this at a local postgres or a cloud-sql-proxy tunnel.
# Example local: postgresql://tunzafy:tunzafy@127.0.0.1:5432/tunzafy
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/tunzafy

# ── URLs ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Optional integrations (leave blank to disable locally) ──────────
OPENAI_API_KEY=
RESEND_API_KEY=

# ── AI Provider Switcher (OpenAI ↔ Gemini/Vertex AI) ────────────────
# Toggle which backend powers TunzAI's chat completions at runtime.
#   OPENAI  → use the existing OpenAI client/logic (default).
#   GEMINI  → use the native Google Vertex AI SDK + our fine-tuned model.
AI_PROVIDER=OPENAI

# Required ONLY when AI_PROVIDER=GEMINI:
#   AI_GEMINI_PROJECT  → GCP project id (e.g. tunzafy)
#   AI_GEMINI_LOCATION → Vertex region (default us-central1)
#   AI_GEMINI_MODEL    → fine-tuned model id OR full endpoint resource path,
#                        supplied once training finishes, e.g.
#                        projects/<proj>/locations/<loc>/endpoints/<endpointId>
AI_GEMINI_PROJECT=
AI_GEMINI_LOCATION=us-central1
AI_GEMINI_MODEL=
